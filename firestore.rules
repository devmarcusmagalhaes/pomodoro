rules_version = '2';

// Regras de segurança do Firestore para o Pomodoro Semanal.
//
// Princípio: cada usuário só pode ler/escrever os PRÓPRIOS dados.
// O isolamento por uid é reforçado aqui no servidor (não dá para confiar
// apenas no app cliente).
service cloud.firestore {
  match /databases/{database}/documents {

    // Documento de perfil: usuarios/{uid}
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Subcoleção de sessões: usuarios/{uid}/sessoes/{sessaoId}
      match /sessoes/{sessaoId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
